{
  "name": "gunswap-contracts",
  "description": "GunSwap — configurable-fee AMM (core + router) for BSC",
  "version": "1.0.1",
  "keywords": [
    "gunswap",
    "bsc",
    "amm",
    "defi"
  ],
  "files": [
    "contracts",
    "build"
  ],
  "engines": {
    "node": ">=16"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.6.1",
    "@openzeppelin/contracts-upgradeable": "^5.6.1",
    "dotenv": "^17.4.2"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-chai-matchers": "^2.0.6",
    "@nomicfoundation/hardhat-ethers": "^3.0.5",
    "@types/chai": "^4.3.11",
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.11.30",
    "chai": "^4.3.10",
    "ethereumjs-util": "^7.1.5",
    "ethers": "^6.13.2",
    "hardhat": "^2.22.10",
    "prettier": "^2.8.8",
    "rimraf": "^3.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  },
  "scripts": {
    "compile": "hardhat compile",
    "clean": "hardhat clean",
    "test": "hardhat test",
    "deploy:bsc": "hardhat run scripts/deploy.ts --network bsc",
    "deploy:testnet": "hardhat run scripts/deploy.ts --network bscTestnet",
    "deploy:mocks": "hardhat run scripts/deploy-mocks.ts --network bsc",
    "create-pools": "hardhat run scripts/create-pools.ts --network bsc",
    "set-feeto": "hardhat run scripts/set-feeto.ts --network bsc",
    "set-fee": "hardhat run scripts/set-swapfee.ts --network bsc",
    "lint": "prettier ./test/**/*.ts --check",
    "lint:fix": "prettier ./test/**/*.ts --write"
  },
  "license": "GPL-3.0-or-later"
}
