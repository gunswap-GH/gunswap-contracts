# ── GunSwap deployment config (template) ──────────────────────
# Copy this file to .env and fill in real values:  cp .env.example .env
# .env is gitignored and will never be committed.

# [REQUIRED] Deployer private key (with or without the 0x prefix).
# Use a DEDICATED deployment wallet funded with just enough BNB for gas —
# never your main wallet's private key.
PRIVATE_KEY=

# [OPTIONAL] Factory owner address (feeToSetter).
# Defaults to the deployer address if left empty.
# A multisig address is recommended for production.
FEE_TO_SETTER=

# [OPTIONAL] Custom RPC endpoints. Leave empty to use the default public nodes.
BSC_RPC_URL=
BSC_TESTNET_RPC_URL=
