# ── GunSwap 部署配置(模板)─────────────────────────────────
# 复制本文件为 .env 再填真实值:  cp .env.example .env
# .env 已被 .gitignore 忽略,不会进版本库。

# 【必填】部署私钥(带不带 0x 前缀都行)。
# 务必用一个【专用部署钱包】,只放够 gas 的少量 BNB,不要用主力钱包私钥。
PRIVATE_KEY=

# 【可选】费率管理员 / owner(Factory 的 feeToSetter)。
# 留空则用部署者地址。建议生产环境填一个多签地址。
FEE_TO_SETTER=

# 【可选】自定义 RPC 节点。留空用默认公共节点。
BSC_RPC_URL=
BSC_TESTNET_RPC_URL=
